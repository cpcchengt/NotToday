{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NotToday",
  "version": "0.1.0",
  "identifier": "com.nottoday.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "NotToday",
        "width": 460,
        "height": 680,
        "minWidth": 400,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "alwaysOnTop": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "useLocalToolsDir": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
